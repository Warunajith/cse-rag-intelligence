# Production env template — copy to .env and fill EVERY value with strong secrets.
# The prod compose REQUIRES these (it fails to start if any are blank).

# ─── OpenAI (required) ───
OPENAI_API_KEY=sk-...
GEN_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o-mini

# ─── Postgres — use a strong password ───
PG_DB=cse_rag
PG_USER=raguser
PG_PASSWORD=

# ─── MinIO — use strong credentials ───
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ─── Redis ───
REDIS_PASSWORD=

# ─── OpenSearch admin (security plugin enabled) ───
# Must meet OpenSearch password policy (length + complexity)
OS_ADMIN_PASSWORD=

# ─── API protection ───
# Clients must send this as a header; the reverse proxy / API checks it.
API_KEY=

# ─── Reranker (optional, hosted recommended in prod) ───
RERANK_ENABLED=false
RERANKER_BACKEND=jina
RERANKER_WITH_LOCAL=false
JINA_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=
